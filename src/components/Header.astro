---
import { Image } from 'astro:assets';
import logoSenties from '../assets/logo-senties.png';
---

<header class="header">
  <div class="header-inner">
    <a href="#" class="logo" aria-label="Inicio">
      <Image
        src={logoSenties}
        alt="Senties Chauvet - Fianzas y Garantías"
        width={1378}
        height={303}
        class="logo-img"
      />
    </a>
    <nav class="nav">
      <a href="#servicios">Servicios</a>
      <a href="#niveles">Niveles de servicio</a>
      <a href="#contacto">Contacto</a>
    </nav>
    <button class="theme-toggle" id="themeToggle" aria-label="Cambiar tema">
      <i class="fa-solid fa-moon"></i>
    </button>
    <a
      href="https://wa.me/5215552002200"
      class="header-cta"
      target="_blank"
      rel="noopener"
    >
      <i class="fa-brands fa-whatsapp"></i> Escríbenos
    </a>
    <button class="mobile-toggle" aria-label="Menú" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
