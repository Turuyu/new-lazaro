---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Partners from '../components/Partners.astro';
import Levels from '../components/Levels.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout>
  <Header />
  <MobileMenu />
  <main>
    <Hero />
    <Services />
    <Partners />
    <Levels />
    <Contact />
    <!-- Floating WhatsApp -->
    <a href="https://wa.me/5215552002200" class="floating-wa" target="_blank" rel="noopener" aria-label="WhatsApp">
      <i class="fa-brands fa-whatsapp"></i>
    </a>
  </main>
  <Footer />
</Layout>

<script>
  import { initTheme } from '../scripts/theme';
  import { initMobileMenu } from '../scripts/mobileMenu';
  import { initHeaderScroll } from '../scripts/headerScroll';

  document.addEventListener('astro:page-load', () => {
    initTheme();
    initMobileMenu();
    initHeaderScroll();
  });
</script>
